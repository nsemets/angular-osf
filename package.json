{
  "name": "osf",
  "version": "26.5.0",
  "scripts": {
    "ng": "ng",
    "analyze-bundle": "ng build --configuration=analyze-bundle && source-map-explorer dist/**/*.js --no-border-checks",
    "build": "ng build",
    "build:ssr": "ng build --configuration=ssr",
    "check:config": "node ./docker/check-config.js",
    "ci:test": "ng test --no-watch",
    "ci:test:coverage": "ng test --no-watch --coverage",
    "docs": "./node_modules/.bin/compodoc -p tsconfig.docs.json --name 'OSF Angular Documentation' --theme 'laravel' -s",
    "docs:coverage": "./node_modules/.bin/compodoc -p tsconfig.docs.json --coverageTest 0 --coverageMinimumPerFile 0",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:format": "npm run lint:fix && npm run format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ngxs:actions": "ng generate @ngxs/store:actions --name --path",
    "ngxs:store": "ng generate @ngxs/store:store --name --path",
    "prepare": "husky",
    "start": "ng serve",
    "start:ssr": "ng serve --configuration dev-ssr",
    "start:docker": "npm run check:config && ng serve --host 0.0.0.0 --port 4200 --poll 2000 --configuration development",
    "start:docker:local": "npm run check:config && ng serve --host 0.0.0.0 --port 4200 --poll 2000 --configuration docker",
    "test": "ng test --no-watch --no-coverage",
    "test:watch": "ng test",
    "test:one": "ng test --no-watch --no-coverage --include",
    "test:coverage": "ng test --no-watch --coverage && npm run test:display",
    "test:check-coverage-thresholds": "node .github/scripts/check-coverage-thresholds.js",
    "test:display": "node .github/counter/counter.test.display.js",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:osf": "node dist/osf/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/platform-server": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/ssr": "^21.2.1",
    "@centerforopenscience/markdown-it-atrules": "^0.1.2",
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.21",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mdit/plugin-img-size": "0.23.1",
    "@newrelic/browser-agent": "^1.310.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@ngxs/store": "^21.0.0",
    "@primeuix/themes": "^2.0.3",
    "@sentry/angular": "^10.42.0",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "ace-builds": "1.43.6",
    "angular-google-tag-manager": "^1.13.0",
    "cedar-artifact-viewer": "^0.9.5",
    "cedar-embeddable-editor": "1.5.0",
    "chart.js": "^4.5.1",
    "diff": "^8.0.3",
    "express": "^5.1.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "markdown-it-video": "^0.6.3",
    "ngx-captcha": "^14.0.0",
    "ngx-cookie-service": "^21.1.0",
    "ngx-markdown-editor": "^5.3.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@compodoc/compodoc": "^1.1.16",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/gapi": "^0.0.47",
    "@types/gapi.auth2": "^0.0.61",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.1",
    "angular-eslint": "^21.3.0",
    "angularx-qrcode": "^21.0.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.2",
    "ng-mocks": "^14.15.1",
    "prettier": "3.8.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "**/*.{ts,html,scss}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "volta": {
    "node": "22.13.1",
    "npm": "10.9.0"
  }
}
